<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:label="@string/app_name"
        android:icon="@drawable/ic_godark"
        android:theme="@style/Theme.GoDark"
        android:supportsRtl="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.GoDark">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Network blackout: occupies the VPN slot and blackholes all traffic -->
        <!-- NOTE: a separate-process (:tunnel) architecture was tested against
             Vivo OriginOS swipe force-stop and did NOT survive: the kill is
             package-level, all processes die. Do not reintroduce android:process
             expecting OEM-kill survival; it only breaks in-memory state sharing. -->
        <service
            android:name=".vpn.GoDarkVpnService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="network_blackout_vpn" />
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <!-- Sentinel: watches for camera / microphone activation -->
        <service
            android:name=".sentinel.SentinelService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="privacy_sensor_monitoring" />
        </service>

        <!-- Quick Settings tile -->
        <service
            android:name=".tile.GoDarkTileService"
            android:exported="true"
            android:icon="@drawable/ic_godark"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

    </application>
</manifest>